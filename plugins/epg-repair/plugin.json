{
  "id": "epg-repair",
  "name": "EPG Repair",
  "version": "1.0.0",
  "api_version": "1.0.0",
  "description": "Scans playlist channels for missing or empty EPG mappings and suggests or applies repairs.",
  "entrypoint": "Plugin.php",
  "class": "AppLocalPlugins\\EpgRepair\\Plugin",
  "capabilities": [
    "epg_repair",
    "scheduled"
  ],
  "hooks": [
    "epg.cache.generated"
  ],
  "permissions": [
    "db_read",
    "db_write",
    "schema_manage",
    "filesystem_write",
    "queue_jobs",
    "hook_subscriptions",
    "scheduled_runs"
  ],
  "schema": {
    "tables": [
      {
        "name": "plugin_epg_repair_scan_candidates",
        "columns": [
          { "name": "id", "type": "id" },
          { "name": "extension_plugin_run_id", "type": "foreignId", "references": "extension_plugin_runs", "on_delete": "cascade" },
          { "name": "source_run_id", "type": "foreignId", "references": "extension_plugin_runs", "nullable": true, "on_delete": "null" },
          { "name": "channel_id", "type": "foreignId", "references": "channels", "on_delete": "cascade" },
          { "name": "playlist_id", "type": "foreignId", "references": "playlists", "nullable": true, "on_delete": "null" },
          { "name": "playlist_name", "type": "string", "nullable": true },
          { "name": "issue", "type": "string", "nullable": true },
          { "name": "decision", "type": "string", "nullable": true },
          { "name": "current_epg_channel_id", "type": "foreignId", "references": "epg_channels", "nullable": true, "on_delete": "null" },
          { "name": "current_epg_channel_name", "type": "string", "nullable": true },
          { "name": "current_epg_source_id", "type": "foreignId", "references": "epgs", "nullable": true, "on_delete": "null" },
          { "name": "current_epg_source_name", "type": "string", "nullable": true },
          { "name": "suggested_epg_channel_id", "type": "foreignId", "references": "epg_channels", "nullable": true, "on_delete": "null" },
          { "name": "suggested_epg_channel_name", "type": "string", "nullable": true },
          { "name": "suggested_epg_source_id", "type": "foreignId", "references": "epgs", "nullable": true, "on_delete": "null" },
          { "name": "suggested_epg_source_name", "type": "string", "nullable": true },
          { "name": "selected_epg_source_id", "type": "foreignId", "references": "epgs", "nullable": true, "on_delete": "null" },
          { "name": "selected_epg_source_name", "type": "string", "nullable": true },
          { "name": "source_scope", "type": "string", "default": "selected_only" },
          { "name": "confidence", "type": "decimal", "nullable": true, "precision": 8, "scale": 4 },
          { "name": "confidence_band", "type": "string", "nullable": true },
          { "name": "match_reason", "type": "string", "nullable": true },
          { "name": "repairable", "type": "boolean", "default": false },
          { "name": "source_candidates", "type": "json", "nullable": true },
          { "name": "apply_outcome", "type": "string", "nullable": true },
          { "name": "applied", "type": "boolean", "default": false },
          { "name": "review_status", "type": "string", "default": "pending" },
          { "name": "reviewed_by_user_id", "type": "foreignId", "references": "users", "nullable": true, "on_delete": "null" },
          { "name": "reviewed_by_user_name", "type": "string", "nullable": true },
          { "name": "reviewed_at", "type": "timestamp", "nullable": true },
          { "name": "last_apply_run_id", "type": "foreignId", "references": "extension_plugin_runs", "nullable": true, "on_delete": "null" },
          { "type": "timestamps" }
        ],
        "indexes": [
          { "type": "unique", "columns": ["extension_plugin_run_id", "channel_id"], "name": "plugin_epg_repair_run_channel_unique" },
          { "type": "index", "columns": ["extension_plugin_run_id", "review_status"], "name": "plugin_epg_repair_run_review_status_idx" },
          { "type": "index", "columns": ["extension_plugin_run_id", "repairable"], "name": "plugin_epg_repair_run_repairable_idx" }
        ]
      }
    ]
  },
  "data_ownership": {
    "tables": [
      "plugin_epg_repair_scan_candidates"
    ],
    "directories": [
      "plugin-reports/epg-repair"
    ],
    "default_cleanup_policy": "preserve"
  },
  "settings": [
    {
      "id": "auto_scan_on_epg_ready",
      "label": "Auto Scan When EPG Cache Completes",
      "type": "boolean",
      "default": true
    },
    {
      "id": "schedule_enabled",
      "label": "Enable Scheduled Scans",
      "type": "boolean",
      "default": false
    },
    {
      "id": "schedule_cron",
      "label": "Schedule Cron",
      "type": "text",
      "default": "0 * * * *"
    },
    {
      "id": "default_playlist_id",
      "label": "Default Playlist",
      "type": "model_select",
      "model": "App\\Models\\Playlist",
      "label_attribute": "name",
      "scope": "owned",
      "helper_text": "Used for auto scans and pre-filled in manual actions. Pick a playlist that has enabled live channels."
    },
    {
      "id": "default_epg_id",
      "label": "Default EPG",
      "type": "model_select",
      "model": "App\\Models\\Epg",
      "label_attribute": "name",
      "scope": "owned",
      "helper_text": "Used for auto scans and pre-filled in manual actions. Pick a synced EPG with channel data."
    },
    {
      "id": "hours_ahead",
      "label": "Hours Ahead",
      "type": "number",
      "default": 12
    },
    {
      "id": "confidence_threshold",
      "label": "Confidence Threshold",
      "type": "number",
      "default": 0.65
    }
  ],
  "actions": [
    {
      "id": "scan",
      "label": "Scan For Repairs",
      "dry_run": true,
      "fields": [
        {
          "id": "playlist_id",
          "label": "Playlist",
          "type": "model_select",
          "model": "App\\Models\\Playlist",
          "label_attribute": "name",
          "scope": "owned",
          "required": true,
          "default_from_setting": "default_playlist_id",
          "helper_text": "Choose a playlist with enabled live channels. If a scan reports 0 channels, this is the first thing to check."
        },
        {
          "id": "epg_id",
          "label": "EPG",
          "type": "model_select",
          "model": "App\\Models\\Epg",
          "label_attribute": "name",
          "scope": "owned",
          "required": true,
          "default_from_setting": "default_epg_id",
          "helper_text": "Choose the EPG you want to repair against."
        },
        {
          "id": "hours_ahead",
          "label": "Hours Ahead",
          "type": "number",
          "default": 12
        },
        {
          "id": "confidence_threshold",
          "label": "Confidence Threshold",
          "type": "number",
          "default": 0.65
        },
        {
          "id": "source_scope",
          "label": "Source Comparison",
          "type": "select",
          "default": "selected_only",
          "options": {
            "selected_only": "Selected EPG only",
            "all_owned": "Compare all owned EPGs"
          },
          "helper_text": "Use the selected EPG only for a focused repair pass, or compare the channel against all of your EPG sources to find the best candidate."
        }
      ]
    },
    {
      "id": "apply",
      "label": "Apply Repairs",
      "requires_confirmation": true,
      "destructive": true,
      "fields": [
        {
          "id": "playlist_id",
          "label": "Playlist",
          "type": "model_select",
          "model": "App\\Models\\Playlist",
          "label_attribute": "name",
          "scope": "owned",
          "required": true,
          "default_from_setting": "default_playlist_id",
          "helper_text": "Choose the same playlist you scanned, ideally one with enabled live channels."
        },
        {
          "id": "epg_id",
          "label": "EPG",
          "type": "model_select",
          "model": "App\\Models\\Epg",
          "label_attribute": "name",
          "scope": "owned",
          "required": true,
          "default_from_setting": "default_epg_id",
          "helper_text": "Choose the same EPG used during the scan so the repair suggestions line up."
        },
        {
          "id": "hours_ahead",
          "label": "Hours Ahead",
          "type": "number",
          "default": 12
        },
        {
          "id": "confidence_threshold",
          "label": "Confidence Threshold",
          "type": "number",
          "default": 0.65
        },
        {
          "id": "apply_scope",
          "label": "Apply Scope",
          "type": "select",
          "default": "safe_only",
          "options": {
            "safe_only": "Safe issues only",
            "unmapped_only": "Unmapped only",
            "broken_only": "Broken mappings only",
            "all_repairable": "All repairable issues"
          },
          "helper_text": "Safe issues skip source-switch repairs unless you explicitly allow them."
        },
        {
          "id": "allow_source_switch",
          "label": "Allow Source Switching",
          "type": "boolean",
          "default": false,
          "helper_text": "If disabled, channels currently mapped to another EPG source will not be reassigned during apply."
        },
        {
          "id": "max_repairs",
          "label": "Maximum Repairs",
          "type": "number",
          "default": 250,
          "helper_text": "Caps how many repairs can be applied in a single run. Use 0 for no limit."
        }
      ]
    },
    {
      "id": "apply_reviewed",
      "label": "Apply Reviewed Repairs",
      "requires_confirmation": true,
      "destructive": true,
      "hidden": true,
      "fields": [
        {
          "id": "source_run_id",
          "label": "Source Scan Run",
          "type": "number",
          "required": true,
          "helper_text": "Internal action used from the scan run review screen."
        }
      ]
    }
  ]
}
